SPECKLE_HOST=your-speckle-host-or-cloud-domain
SPECKLE_TOKEN=your-speckle-token
SPECKLE_PROJECT_ID=your-project-id
SPECKLE_MODEL_ID=your-model-id
SPECKLE_USE_SSL=true

MQTT_BROKER=your-mqtt-broker
MQTT_PORT=1883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password
MQTT_TOPICS=site1/sensor/temperature/state,site1/sensor/humidity/state
MQTT_KEEPALIVE=60
SPECKLE_MIN_SEND_INTERVAL_SECONDS=60
SPECKLE_SKIP_DUPLICATE_PAYLOADS=true
SPECKLE_SENSOR_THRESHOLDS=temperature=0.5,humidity=2,pm25=5

LOG_LEVEL=INFO
SPECKLE_ARC_TIMEZONE=Asia/Bangkok

# Self-hosted only:
SPECKLE_PUBLIC_HOST=your-speckle-host
SPECKLE_CANONICAL_URL=http://your-speckle-host:8080
SPECKLE_FRONTEND_ORIGIN=http://your-speckle-host:8080
SPECKLE_API_ORIGIN=http://your-speckle-host:3000
SPECKLE_SESSION_SECRET=replace-with-long-random-secret
SPECKLE_POSTGRES_PASSWORD=replace-with-postgres-password
SPECKLE_S3_ACCESS_KEY=speckleadmin
SPECKLE_S3_SECRET_KEY=replace-with-minio-password
SPECKLE_S3_BUCKET=speckle-objects
